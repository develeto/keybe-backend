{
  "name": "order-flow",
  "version": "1.0.0",
  "description": "OrderFlow — Backend Serverless para gestión de pedidos",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest test/unit",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest test/e2e",
    "cdk": "cdk --profile keybe",
    "cdk:bootstrap": "cdk bootstrap --profile keybe",
    "cdk:deploy": "cdk deploy --require-approval never --profile keybe",
    "cdk:diff": "cdk diff --profile keybe",
    "cdk:synth": "cdk synth --profile keybe",
    "cdk:destroy": "cdk destroy --profile keybe"
  },
  "keywords": [
    "orderflow",
    "serverless",
    "aws",
    "cdk"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/bcryptjs": "~2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.9",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "aws-cdk": "^2.180.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.33.0",
    "eslint-plugin-jest": "^29.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.970.0",
    "@aws-sdk/client-secrets-manager": "^3.970.0",
    "@aws-sdk/client-sns": "^3.1073.0",
    "@aws-sdk/client-sqs": "^3.970.0",
    "@aws-sdk/credential-providers": "^3.876.0",
    "aws-cdk-lib": "^2.180.0",
    "bcryptjs": "^2.4.3",
    "constructs": "^10.4.2",
    "kysely": "^0.27.6",
    "mysql2": "^3.14.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  }
}
